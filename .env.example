# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask session security (required)
FLASK_SECRET_KEY=

# Flask server config (optional — defaults shown)
# FLASK_DEBUG=false          # Set to true only during local development
# FLASK_HOST=127.0.0.1       # Use 0.0.0.0 only if deploying behind a reverse proxy
# FLASK_PORT=5000

# Allowed CORS origins (comma-separated, optional — defaults to localhost:5000)
# CORS_ORIGINS=http://localhost:5000,https://yourdomain.com

# MongoDB Atlas connection (optional — app uses local JSON fallback if unset)
MONGO_URI=
MONGO_DB_NAME=neuroscan_db

# Cloudinary image storage (required for scan history uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
